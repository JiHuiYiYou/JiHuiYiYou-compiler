// arena_test.jhyy — driver that exercises arena.jhyy
// Tests the bump allocator by:
//   1. Allocating an arena
//   2. Allocating many objects (verifying it grows blocks)
//   3. Resetting the arena (all blocks reused)
//   4. Freeing the arena (returns memory to libc)

import arena;

extern fn printf(fmt: *u8, val: i32) -> i32;

fn main_jhyy() -> i32 {
    let mut a: Arena = Arena { start: 0 as *u8, cur: 0 as *u8, end: 0 as *u8, blocks: 0 as *ArenaBlock, def_size: 0 };
    arena_init(&a, 1024);  // 1 KB default block

    // Allocate a small object (8 bytes, aligned to 8)
    let p1 = arena_alloc(&a, 8);
    printf("p1: %d\n", p1 as i32);

    // Allocate many objects to force block growth
    let mut i: i32 = 0;
    while i < 200 {
        let p = arena_alloc(&a, 16);
        i = i + 1;
    }
    printf("allocated 200 objects\n");

    // Test calloc
    let z = arena_calloc(&a, 32);
    printf("calloc: %d\n", z as i32);

    // Test strdup with "hello"
    let hello = "hello" as *u8;
    let dup = arena_strdup(&a, hello, 5);
    printf("dup: %d\n", dup as i32);

    // Reset (keeps blocks, resets cur)
    arena_reset(&a);
    printf("after reset\n");

    // Free everything
    arena_free(&a);
    printf("after free\n");

    0
}