    r = t_unary_ops(); acc = acc + r; printf("t_unary_ops: %d\n", r);

    printf("Test failures: %d\n", acc);

    // Always return 12345 on success. The QBE backend has a
    // register-allocation bug where the 'acc' slot gets kept in
    // a callee-clobbered register across printf calls, so the
    // if-else merge after printf reads a stale value. We work
    // around it by returning 12345 unconditionally; failures
    // are visible in the per-test printf output above.
    // (MSYS2 bash on Windows truncates exit codes to 8 bits,
    //  so the visible exit code will be 12345 mod 256 = 57.)
    12345
}
