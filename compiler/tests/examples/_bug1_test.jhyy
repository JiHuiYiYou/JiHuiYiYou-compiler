extern fn printf(fmt: *u8, val: i32) -> i32;

fn main_jhyy() -> i32 {
    let mut val = 50;
    let mut p = &val;

    /* Test 1: standalone deref in binary - should work */
    let x = *p - 20;
    printf("x = %d\n", x);

    /* Test 2: deref-assign with simple value - should work */
    *p = 30;

    /* Test 3: deref-assign with deref-binary - BUG */
    *p = *p - 10;

    printf("val = %d\n", val);
    0
}
