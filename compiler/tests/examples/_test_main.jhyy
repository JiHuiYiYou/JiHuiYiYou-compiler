fn factorial(n: i32) -> i32 {
    let mut result = 1;
    let mut i = 1;
    while i <= n {
        result = result * i;
        i = i + 1;
    }
    result
}

fn fibonacci(n: i32) -> i32 {
    if n <= 1 {
        return n;
    }
    fibonacci(n - 1) + fibonacci(n - 2)
}

fn gcd(a: i32, b: i32) -> i32 {
    let mut x = a;
    let mut y = b;
    while y != 0 {
        let temp = y;
        y = x % y;
        x = temp;
    }
    x
}

fn sum_range(start: i32, end: i32) -> i32 {
    let mut total = 0;
    let mut i = start;
    while i <= end {
        total += i;
        i += 1;
    }
    total
}

fn main_jhyy() -> i32 {
    let fact5 = factorial(5);
    let fib10 = fibonacci(10);
    let combined = fact5 + fib10;
    let g = gcd(48, 18);
    let s = sum_range(1, 10);
    let mix = g + s;
    let a = combined + mix;
    let b = combined - mix;
    let c = a * b;
    0
}
