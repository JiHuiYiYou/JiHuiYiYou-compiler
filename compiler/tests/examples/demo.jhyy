// ============================================================
// jhyy 语言特性演示
// ============================================================

// 阶乘 — 演示 while 循环 + mut 变量
fn factorial(n: i32) -> i32 {
    let mut result = 1;
    let mut i = 1;
    while i <= n {
        result = result * i;
        i = i + 1;
    }
    result
}

// 斐波那契 — 演示递归
fn fibonacci(n: i32) -> i32 {
    if n <= 1 {
        return n;
    }
    fibonacci(n - 1) + fibonacci(n - 2)
}

// 最大公约数
fn gcd(a: i32, b: i32) -> i32 {
    let mut x = a;
    let mut y = b;
    while y != 0 {
        let temp = y;
        y = x % y;
        x = temp;
    }
    x
}

// 区间求和
fn sum_range(start: i32, end: i32) -> i32 {
    let mut total = 0;
    let mut i = start;
    while i <= end {
        total += i;
        i += 1;
    }
    total
}

// 主入口
fn main_jhyy() -> i32 {
    // 函数调用
    let fact5 = factorial(5);
    let fib10 = fibonacci(10);
    // 立即用函数结果做运算
    let combined = fact5 + fib10;

    // 更多函数调用
    let g = gcd(48, 18);
    let s = sum_range(1, 10);
    // 立即组合
    let mix = g + s;

    // 算术
    let a = combined + mix;
    let b = combined - mix;
    let c = a * b;
    let d = c / 10;
    let e = d % 7;

    // 比较
    let t = a == c;
    let u = a < c;
    let v = a > d;

    // 逻辑
    let logic_a = t && u;
    let logic_b = v || (!t);

    // 位运算
    let bits = 0xFF & 0x0F;
    let shifted = bits << 4;

    // mut 和复合赋值
    let mut counter = 1;
    counter += 2;
    counter *= 3;
    counter -= 1;
    let final_count = counter;

    0
}

