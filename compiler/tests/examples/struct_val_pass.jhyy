// Test: struct as function parameter (pass by value)
type Point = struct {
    x: i32,
    y: i32
}

extern fn printf(fmt: *u8, val: i32) -> i32;

fn sum_point(p: Point) -> i32 {
    p.x + p.y
}

fn main_jhyy() -> i32 {
    let p = Point { x: 10, y: 25 };
    let result = sum_point(p);
    result  // 10 + 25 = 35
}
