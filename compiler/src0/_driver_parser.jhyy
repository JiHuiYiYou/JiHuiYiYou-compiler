    let module = parser_parse(p);
    let md = node_module_data(module);
    let slot = (*md).decls as **Node;
    let decl = *slot;
    let fd = node_func_decl_data(decl);
    let p0 = (*fd).params as *NodeFuncDeclParam;
    let ptype = (*p0).type_annot as *Node;
    if (*ptype).kind != NODE_ARRAY_TYPE() {
        printf("FAIL T11 kind got=%d\n", (*ptype).kind); return 100;
    }
    return 0;
}

// ── Test 12: qualified type std::module::Type ──
fn test_type_qualified(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T12\n", 0);
    let src = "type MyType = std::io::Buffer;" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*module).kind != NODE_MODULE() {
        printf("FAIL T12 module kind\n", 0); return 110;
    }
    let md = node_module_data(module);
    if (*md).ndeccls != (1 as i64) {
        printf("FAIL T12 ndeccls\n", 0); return 110;
    }
    let slot = (*md).decls as **Node;
    let decl = *slot;
    if (*decl).kind != NODE_TYPE_DECL() {
        printf("FAIL T12 decl kind\n", 0); return 110;
    }
    let td = node_type_decl_data(decl);
    // body = 最右 ident "Buffer"（:: 反复赋值 base）
    if (*((*td).body as *Node)).kind != NODE_IDENT() {
        printf("FAIL T12 body kind\n", 0); return 111;
    }
    let id = node_ident_data((*td).body);
    let sym = (*id).sym as *Sym;
    if strcmp((*sym).name, "Buffer" as *u8) != (0 as i32) {
        printf("FAIL T12 body sym name\n", 0); return 112;
    }
    return 0;
}

// ── Test 13: error detection（缺 ; → error_count 增加） ──
fn test_error(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T13\n", 0);
    // 缺 ; in fn decl — 但 parser_expect 只在 parse_func 内部检查 extern 的 ;
    // 内部 expect 在 body 的 RBRACE 失败时也会报错。这里故意写一个缺 ) 的 fn。
    let src = "fn bad(a: i32 { }" as *u8;  // 缺 ) 在参数列表
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count == (0 as i32) {
        printf("FAIL T13 error_count\n", 0); return 120;
    }
    return 0;
}

// ═══ Sprint 3 commit 3: parse_stmt + parse_pattern 测试 ═══

// ── Test 14: parse_let（带 mut + type annotation） ──
fn test_parse_let(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T14\n", 0);
    let src = "fn f() -> i32 { let mut x: i32 = 0; 0 }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T14 error_count=%d\n", (*p).error_count); return 130;
    }
    // 进入 fn body 找到 NODE_LET
    let md = node_module_data(module);
    let slot = (*md).decls as **Node;
    let fn_decl = *slot;
    let fd = node_func_decl_data(fn_decl);
    let body = (*fd).body as *Node;
    let bd = node_block_data(body);
    // commit 4 parse_expr 是完整 Pratt：trailing `0` 现在是 NODE_EXPR_STMT，
    // body 块有 2 个 stmt（let + expr_stmt）
    if (*bd).nstmts != (2 as i64) {
        printf("FAIL T14 nstmts got=%d\n", (*bd).nstmts as i32); return 131;
    }
    let s0 = *(((*bd).stmts as i64) as **Node);
    if (*s0).kind != NODE_LET() {
        printf("FAIL T14 s0 kind got=%d\n", (*s0).kind); return 132;
    }
    let ld = node_let_data(s0);
    if (*ld).is_mutable != (1 as i32) {
        printf("FAIL T14 is_mutable\n", 0); return 133;
    }
    let sym = (*ld).sym as *Sym;
    if strcmp((*sym).name, "x" as *u8) != (0 as i32) {
        printf("FAIL T14 sym name\n", 0); return 134;
    }
    // commit 4 新增：let init = NODE_INT 0（不再是 NULL）
    let init = (*ld).init as *Node;
    if init == (0 as *Node) {
        printf("FAIL T14 init null\n", 0); return 135;
    }
    if (*init).kind != NODE_INT() {
        printf("FAIL T14 init kind got=%d\n", (*init).kind); return 136;
    }
    // s1 = NODE_EXPR_STMT（trailing `0`）
    let s1 = *(((*bd).stmts as i64 + (8 as i64)) as **Node);
    if (*s1).kind != NODE_EXPR_STMT() {
        printf("FAIL T14 s1 kind got=%d\n", (*s1).kind); return 137;
    }
    return 0;
}

// ── Test 15: parse_if (无 else) ──
fn test_parse_if_no_else(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T15\n", 0);
    let src = "fn f() -> i32 { if 1 { 0 } 0 }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T15 error_count=%d\n", (*p).error_count); return 140;
    }
    let md = node_module_data(module);
    let slot = (*md).decls as **Node;
    let fn_decl = *slot;
    let fd = node_func_decl_data(fn_decl);
    let body = (*fd).body as *Node;
    let bd = node_block_data(body);
    // nstmts = 1 (if, the trailing 0 → expr stub NULL)
    if (*bd).nstmts < (1 as i64) {
        printf("FAIL T15 nstmts\n", 0); return 141;
    }
    let s0 = *(((*bd).stmts as i64) as **Node);
    if (*s0).kind != NODE_IF() {
        printf("FAIL T15 s0 kind got=%d\n", (*s0).kind); return 142;
    }
    let id = node_if_data(s0);
    if (*id).else_body != (0 as *u8) {
        printf("FAIL T15 else_body should be null\n", 0); return 143;
    }
    if (*id).then_body == (0 as *u8) {
        printf("FAIL T15 then_body null\n", 0); return 144;
    }
    return 0;
}

// ── Test 16: parse_if (with else) ──
fn test_parse_if_else(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T16\n", 0);
    let src = "fn f() -> i32 { if 1 { 0 } else { 0 } 0 }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T16 error_count=%d\n", (*p).error_count); return 150;
    }
    let md = node_module_data(module);
    let slot = (*md).decls as **Node;
    let fn_decl = *slot;
    let fd = node_func_decl_data(fn_decl);
    let body = (*fd).body as *Node;
    let bd = node_block_data(body);
    let s0 = *(((*bd).stmts as i64) as **Node);
    if (*s0).kind != NODE_IF() {
        printf("FAIL T16 s0 kind got=%d\n", (*s0).kind); return 151;
    }
    let id = node_if_data(s0);
    if (*id).else_body == (0 as *u8) {
        printf("FAIL T16 else_body null\n", 0); return 152;
    }
    let eb = (*id).else_body as *Node;
    if (*eb).kind != NODE_BLOCK() {
        printf("FAIL T16 else kind got=%d\n", (*eb).kind); return 153;
    }
    return 0;
}

// ── Test 17: parse_while ──
fn test_parse_while(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T17\n", 0);
    let src = "fn f() -> i32 { while 1 { break; } 0 }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T17 error_count=%d\n", (*p).error_count); return 160;
    }
    let md = node_module_data(module);
    let slot = (*md).decls as **Node;
    let fn_decl = *slot;
    let fd = node_func_decl_data(fn_decl);
    let body = (*fd).body as *Node;
    let bd = node_block_data(body);
    let s0 = *(((*bd).stmts as i64) as **Node);
    if (*s0).kind != NODE_WHILE() {
        printf("FAIL T17 s0 kind got=%d\n", (*s0).kind); return 161;
    }
    let wd = node_while_data(s0);
    if (*wd).body == (0 as *u8) {
        printf("FAIL T17 body null\n", 0); return 162;
    }
    // body = block with 1 stmt (break)
    let wb = (*wd).body as *Node;
    let wbd = node_block_data(wb);
    if (*wbd).nstmts != (1 as i64) {
        printf("FAIL T17 nstmts got=%d\n", (*wbd).nstmts as i32); return 163;
    }
    let bs = *(((*wbd).stmts as i64) as **Node);
    if (*bs).kind != NODE_BREAK() {
        printf("FAIL T17 inner kind got=%d\n", (*bs).kind); return 164;
    }
    return 0;
}

// ── Test 18: parse_for ──
fn test_parse_for(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T18\n", 0);
    let src = "fn f() -> i32 { for i in 0..10 { continue; } 0 }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T18 error_count=%d\n", (*p).error_count); return 170;
    }
    let md = node_module_data(module);
    let slot = (*md).decls as **Node;
    let fn_decl = *slot;
    let fd = node_func_decl_data(fn_decl);
    let body = (*fd).body as *Node;
    let bd = node_block_data(body);
    let s0 = *(((*bd).stmts as i64) as **Node);
    if (*s0).kind != NODE_FOR() {
        printf("FAIL T18 s0 kind got=%d\n", (*s0).kind); return 171;
    }
    let fd2 = node_for_data(s0);
    let sym = (*fd2).var as *Sym;
    if strcmp((*sym).name, "i" as *u8) != (0 as i32) {
        printf("FAIL T18 var name\n", 0); return 172;
    }
    return 0;
}

// ── Test 19: parse_match + parse_pattern 短名 variant ──
fn test_parse_match_short_variant(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T19\n", 0);
    // 先 type Option = enum { Some(i32), None } 再 match opt { Some(_) => 1, None => 0 }
    // 单行 — 字符串字面量里的 \n 是字面字节，不是换行
    let src = "type Option = enum { Some(i32), None } fn f(opt: Option) -> i32 { match opt { Some(_) => 1, None => 0 } 0 }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T19 error_count=%d\n", (*p).error_count); return 180;
    }
    let md = node_module_data(module);
    if (*md).ndeccls != (2 as i64) {
        printf("FAIL T19 ndeccls got=%d\n", (*md).ndeccls as i32); return 181;
    }
    // 第二个 decl = fn
    let fn_slot = ((*md).decls as i64 + (8 as i64)) as **Node;
    let fn_decl = *fn_slot;
    let fd = node_func_decl_data(fn_decl);
    let body = (*fd).body as *Node;
    let bd = node_block_data(body);
    // block: 1 stmt = match
    let s0 = *(((*bd).stmts as i64) as **Node);
    if (*s0).kind != NODE_MATCH() {
        printf("FAIL T19 s0 kind got=%d\n", (*s0).kind); return 182;
    }
    let mdata = node_match_data(s0);
    if (*mdata).narms != (2 as i64) {
        printf("FAIL T19 narms got=%d\n", (*mdata).narms as i32); return 183;
    }
    // arm 0: Some(_) → NODE_PATTERN_ENUM, type_sym=NULL, variant_sym=SYM_VARIANT
    let arm0 = *(((*mdata).arms as i64) as **Node);
    let arm0d = node_match_arm_data(arm0);
    let pat0 = (*arm0d).pattern as *Node;
    if (*pat0).kind != NODE_PATTERN_ENUM() {
        printf("FAIL T19 pat0 kind got=%d\n", (*pat0).kind); return 184;
    }
    let pdata = node_pattern_enum_data(pat0);
    let vsym = (*pdata).variant_sym as *Sym;
    if (*vsym).kind != SYM_VARIANT() {
        printf("FAIL T19 vsym kind got=%d\n", (*vsym).kind); return 185;
    }
    if strcmp((*vsym).name, "Some" as *u8) != (0 as i32) {
        printf("FAIL T19 vsym name got=%s\n", (*vsym).name); return 186;
    }
    // inner = NODE_PATTERN_WILD (_)
    let inner = (*pdata).inner as *Node;
    if (*inner).kind != NODE_PATTERN_WILD() {
        printf("FAIL T19 inner kind got=%d\n", (*inner).kind); return 187;
    }
    return 0;
}

// ── Test 20: parse_match 完整限定 Option::Some(v) ──
fn test_parse_match_qualified_enum(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T20\n", 0);
    let src = "type Option = enum { Some(i32), None } fn f(opt: Option) -> i32 { match opt { Option::Some(_) => 1, Option::None => 0 } 0 }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T20 error_count=%d\n", (*p).error_count); return 190;
    }
