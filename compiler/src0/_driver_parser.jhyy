// ── Test 23: nested control flow (if inside for) ──
fn test_nested_if_for(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T23\n", 0);
    let src = "fn f() -> i32 { for i in 0..10 { if 1 { break; } } 0 }" as *u8;
