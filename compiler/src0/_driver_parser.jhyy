// ── Test 30: parse_expr 字面量组合（int + float + string + bool） ──
fn test_expr_literals(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T30\n", 0);
    // 多个 let 验证 4 种字面量 prefix
    let src = "fn f() -> i32 { let i = 42; let f = 3.14; let s = \"hi\"; let b = true; 0 }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T30 error_count=%d\n", (*p).error_count); return 300;
    }
    let md = node_module_data(module);
    let slot = (*md).decls as **Node;
    let fn_decl = *slot;
    let fd = node_func_decl_data(fn_decl);
    let body = (*fd).body as *Node;
    let bd = node_block_data(body);
    // 4 lets + 1 expr_stmt = 5 stmts
    if (*bd).nstmts != (5 as i64) {
        printf("FAIL T30 nstmts got=%d\n", (*bd).nstmts as i32); return 301;
    }
    // s0 = let i = 42 (NODE_INT)
    let s0 = *(((*bd).stmts as i64 + (0 as i64) * (8 as i64)) as **Node);
    let l0 = node_let_data(s0);
    let i0 = (*l0).init as *Node;
    if (*i0).kind != NODE_INT() { printf("FAIL T30 s0 init kind got=%d\n", (*i0).kind); return 302; }
    // s1 = let f = 3.14 (NODE_FLOAT)
    let s1 = *(((*bd).stmts as i64 + (1 as i64) * (8 as i64)) as **Node);
    let l1 = node_let_data(s1);
    let f1 = (*l1).init as *Node;
    if (*f1).kind != NODE_FLOAT() { printf("FAIL T30 s1 init kind got=%d\n", (*f1).kind); return 303; }
    // s2 = let s = "hi" (NODE_STRING, len=2)
    let s2 = *(((*bd).stmts as i64 + (2 as i64) * (8 as i64)) as **Node);
    let l2 = node_let_data(s2);
    let st2 = (*l2).init as *Node;
    if (*st2).kind != NODE_STRING() { printf("FAIL T30 s2 init kind got=%d\n", (*st2).kind); return 304; }
    let strd = node_string_data(st2);
    if (*strd).len != (2 as i64) { printf("FAIL T30 s2 len got=%d\n", (*strd).len as i32); return 305; }
    // s3 = let b = true (NODE_BOOL, val=1)
    let s3 = *(((*bd).stmts as i64 + (3 as i64) * (8 as i64)) as **Node);
    let l3 = node_let_data(s3);
    let b3 = (*l3).init as *Node;
    if (*b3).kind != NODE_BOOL() { printf("FAIL T30 s3 init kind got=%d\n", (*b3).kind); return 306; }
    let bd3 = node_bool_data(b3);
    if (*bd3).value != (1 as i32) { printf("FAIL T30 s3 val got=%d\n", (*bd3).value); return 307; }
    return 0;
}

// ── Test 31: parse_expr 优先级（a + b * c 应该解析为 a + (b*c)） ──
fn test_expr_precedence(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T31\n", 0);
    let src = "fn f() -> i32 { let x = 1 + 2 * 3; x }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T31 error_count=%d\n", (*p).error_count); return 310;
    }
    let md = node_module_data(module);
    let slot = (*md).decls as **Node;
    let fn_decl = *slot;
    let fd = node_func_decl_data(fn_decl);
    let body = (*fd).body as *Node;
    let bd = node_block_data(body);
    let s0 = *(((*bd).stmts as i64) as **Node);
    let ld = node_let_data(s0);
    let init = (*ld).init as *Node;
    // 顶层应该是 +（PREC_TERM 比 PREC_FACTOR 低）
    if (*init).kind != NODE_BINARY() {
        printf("FAIL T31 root kind got=%d\n", (*init).kind); return 311;
    }
    let top = node_binary_data(init);
    if (*top).op != TOKEN_PLUS() {
        printf("FAIL T31 root op got=%d\n", (*top).op); return 312;
    }
    // top.left = 1, top.right = 2 * 3
    let top_left = (*top).left as *Node;
    if (*top_left).kind != NODE_INT() { printf("FAIL T31 left kind got=%d\n", (*top_left).kind); return 313; }
    let top_right = (*top).right as *Node;
    if (*top_right).kind != NODE_BINARY() { printf("FAIL T31 right kind got=%d\n", (*top_right).kind); return 314; }
    let inner = node_binary_data(top_right);
    if (*inner).op != TOKEN_STAR() {
        printf("FAIL T31 inner op got=%d\n", (*inner).op); return 315;
    }
    return 0;
}

// ── Test 32: parse_expr 赋值 x = 42 ──
fn test_expr_assign(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T32\n", 0);
    let src = "fn f() -> i32 { let mut x = 0; x = 42; 0 }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T32 error_count=%d\n", (*p).error_count); return 320;
    }
    let md = node_module_data(module);
    let slot = (*md).decls as **Node;
    let fn_decl = *slot;
    let fd = node_func_decl_data(fn_decl);
    let body = (*fd).body as *Node;
    let bd = node_block_data(body);
    // s0 = let, s1 = assign stmt, s2 = expr stmt 0
    if (*bd).nstmts != (3 as i64) { printf("FAIL T32 nstmts got=%d\n", (*bd).nstmts as i32); return 321; }
    let s1 = *(((*bd).stmts as i64 + (1 as i64) * (8 as i64)) as **Node);
    if (*s1).kind != NODE_EXPR_STMT() {
        printf("FAIL T32 s1 kind got=%d\n", (*s1).kind); return 322;
    }
    let esd = node_expr_stmt_data(s1);
    let inner = (*esd).expr as *Node;
    if (*inner).kind != NODE_ASSIGN() {
        printf("FAIL T32 assign kind got=%d\n", (*inner).kind); return 323;
    }
    return 0;
}

// ── Test 33: parse_expr 数组字面量 [1, 2, 3] ──
fn test_expr_array_lit(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T33\n", 0);
    let src = "fn f() -> i32 { let x = [1, 2, 3]; 0 }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T33 error_count=%d\n", (*p).error_count); return 330;
    }
    let md = node_module_data(module);
    let slot = (*md).decls as **Node;
    let fn_decl = *slot;
    let fd = node_func_decl_data(fn_decl);
    let body = (*fd).body as *Node;
    let bd = node_block_data(body);
    let s0 = *(((*bd).stmts as i64) as **Node);
    let ld = node_let_data(s0);
    let init = (*ld).init as *Node;
    if (*init).kind != NODE_ARRAY_LIT() {
        printf("FAIL T33 init kind got=%d\n", (*init).kind); return 331;
    }
    let ald = node_array_lit_data(init);
    if (*ald).nelems != (3 as i64) {
        printf("FAIL T33 nelems got=%d\n", (*ald).nelems as i32); return 332;
    }
    return 0;
}

// ── Test 34: parse_expr 字符串字面量（含引号剥离） ──
fn test_expr_string(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T34\n", 0);
    let src = "fn f() -> i32 { let s = \"hello world\"; 0 }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T34 error_count=%d\n", (*p).error_count); return 340;
    }
    let md = node_module_data(module);
    let slot = (*md).decls as **Node;
    let fn_decl = *slot;
    let fd = node_func_decl_data(fn_decl);
    let body = (*fd).body as *Node;
    let bd = node_block_data(body);
    let s0 = *(((*bd).stmts as i64) as **Node);
    let ld = node_let_data(s0);
    let init = (*ld).init as *Node;
    if (*init).kind != NODE_STRING() {
        printf("FAIL T34 init kind got=%d\n", (*init).kind); return 341;
    }
    let sd = node_string_data(init);
    if (*sd).len != (11 as i64) {  // "hello world" 中间 11 字符
        printf("FAIL T34 len got=%d\n", (*sd).len as i32); return 342;
    }
    return 0;
}

fn main_jhyy() -> i32 {
    printf("T0\n", 0);

    let mut a: Arena = Arena {
