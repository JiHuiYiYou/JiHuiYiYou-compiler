// ── Test 25: parse_expr 整数字面量 + 二元加法 ──
fn test_expr_int_add(lex: *Lexer, p: *Parser, a: *Arena) -> i32 {
    printf("T25\n", 0);
    let src = "fn f() -> i32 { let x = 1 + 2; x }" as *u8;
    setup_parser(src, lex, p, a);
    let module = parser_parse(p);
    if (*p).error_count != (0 as i32) {
        printf("FAIL T25 error_count=%d\n", (*p).error_count); return 250;
    }
    let md = node_module_data(module);
    let slot = (*md).decls as **Node;
    let fn_decl = *slot;
    let fd = node_func_decl_data(fn_decl);
    let body = (*fd).body as *Node;
    let bd = node_block_data(body);
    let s0 = *(((*bd).stmts as i64) as **Node);
    if (*s0).kind != NODE_LET() {
        printf("FAIL T25 s0 kind got=%d\n", (*s0).kind); return 251;
    }
    let ld = node_let_data(s0);
    let init = (*ld).init as *Node;
    if (*init).kind != NODE_BINARY() {
        printf("FAIL T25 init kind got=%d\n", (*init).kind); return 252;
    }
    let bd2 = node_binary_data(init);
    if (*bd2).op != TOKEN_PLUS() {
        printf("FAIL T25 op got=%d\n", (*bd2).op); return 253;
    }
    // left = NODE_INT 1, right = NODE_INT 2
    let left = (*bd2).left as *Node;
    let right = (*bd2).right as *Node;
    if (*left).kind != NODE_INT() {
        printf("FAIL T25 left kind got=%d\n", (*left).kind); return 254;
    }
    if (*right).kind != NODE_INT() {
        printf("FAIL T25 right kind got=%d\n", (*right).kind); return 255;
    }
    let ld_left = node_int_data(left);
    let ld_right = node_int_data(right);
    if (*ld_left).value != (1 as i64) {
        printf("FAIL T25 left val got=%d\n", (*ld_left).value as i32); return 256;
    }
    if (*ld_right).value != (2 as i64) {
        printf("FAIL T25 right val got=%d\n", (*ld_right).value as i32); return 257;
    }
    return 0;
}

