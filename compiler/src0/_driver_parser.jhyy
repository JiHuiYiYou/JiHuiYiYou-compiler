    let pat0 = (*arm0d).pattern as *Node;
    if (*pat0).kind != NODE_PATTERN_LIT() {
        printf("FAIL T21 pat0 kind got=%d\n", (*pat0).kind); return 202;
    }
    let pd = node_pattern_lit_data(pat0);
    if (*pd).value != (0 as i64) {
        printf("FAIL T21 pat0 value got=%d\n", (*pd).value as i32); return 203;
    }
    // arm 1: pat = NODE_PATTERN_LIT, value=1
    let arm1 = *(((*mdata).arms as i64 + (8 as i64)) as **Node);
    let arm1d = node_match_arm_data(arm1);
    let pat1 = (*arm1d).pattern as *Node;
    let pd1 = node_pattern_lit_data(pat1);
    if (*pd1).value != (1 as i64) {
        printf("FAIL T21 pat1 value got=%d\n", (*pd1).value as i32); return 204;
    }
    return 0;
}

